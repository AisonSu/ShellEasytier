#!/bin/sh /etc/rc.common

START=95
USE_PROCD=1

APPDIR=/etc/ShellEasytier

start_service() {
    [ -f "$APPDIR/.start_error" ] && return 1
    procd_open_instance
    procd_set_param command "$APPDIR/start.sh" daemon-run
    procd_set_param respawn
    procd_close_instance
}

stop_service() {
    kill -TERM "$(cat /tmp/ShellEasytier/easytier.pid 2>/dev/null)" 2>/dev/null
    rm -f /tmp/ShellEasytier/easytier.pid
    killall easytier-core 2>/dev/null
}
