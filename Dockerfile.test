# ShellEasytier 自动化测试 Docker 镜像
FROM alpine:3.19

# 安装测试依赖（这个层很少变化，会被缓存）
RUN apk add --no-cache \
    bash \
    curl \
    wget \
    git \
    shellcheck \
    jq \
    make \
    file \
    ncurses \
    && rm -rf /var/cache/apk/*

# 设置工作目录
WORKDIR /app

# 复制入口脚本（这个文件很少变化，会被缓存）
COPY test/docker-entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

# 复制项目文件（这些文件经常变化，放在最后）
COPY . /app/

# 设置执行权限
RUN chmod +x /app/scripts/*.sh \
    && chmod +x /app/scripts/libs/*.sh \
    && chmod +x /app/scripts/menus/*.sh \
    && chmod +x /app/test/*.sh \
    && chmod +x /app/install.sh \
    && chmod +x /app/build.sh

# 设置入口点
ENTRYPOINT ["/app/entrypoint.sh"]
