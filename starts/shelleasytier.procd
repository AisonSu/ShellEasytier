#!/bin/sh /etc/rc.common
# Copyright (C) ShellEasytier

START=99
STOP=10

USE_PROCD=1

start_service() {
    procd_open_instance
    procd_set_param command /etc/ShellEasytier/scripts/check_and_start.sh
    procd_set_param respawn
    procd_close_instance
}

stop_service() {
    killall easytier-core 2>/dev/null
}
